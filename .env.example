# Server-side only. Never prefix these with VITE_.
# Set these in Netlify → Site configuration → Environment variables.

OPENAI_API_KEY=

# Must match your live site origin exactly (no trailing slash).
PORTFOLIO_ORIGIN=https://raghavaroraportfolio.netlify.app

# Optional but recommended for stronger cross-instance rate limiting (free Upstash Redis).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
